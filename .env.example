# Agentic RAG Platform - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# SERVER CONFIG
# ===========================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://agentic:agentic_password@localhost:5432/agentic_rag
REDIS_URL=redis://localhost:6379

# ===========================================
# LLM API KEYS (add the ones you have)
# ===========================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AI...
MISTRAL_API_KEY=...
GROQ_API_KEY=gsk_...

# Local Ollama (if running)
OLLAMA_BASE_URL=http://localhost:11434

# ===========================================
# DEFAULT LLM SETTINGS
# ===========================================
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
DEFAULT_EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=1536

# ===========================================
# CHROMADB (Vector Database)
# ===========================================
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=agentic_rag_docs

# ===========================================
# GITHUB INTEGRATION
# ===========================================
GITHUB_TOKEN=ghp_...
GITHUB_DEFAULT_ORG=

# ===========================================
# DEPLOYMENT KEYS
# ===========================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
VERCEL_TOKEN=

# ===========================================
# WORKSPACE
# ===========================================
WORKSPACE_ROOT=./workspaces
MAX_WORKSPACES=50
MAX_WORKSPACE_SIZE_MB=500

# ===========================================
# AGENT SETTINGS
# ===========================================
AGENT_MAX_ITERATIONS=25
AGENT_TIMEOUT_MS=120000
AGENT_MAX_CONCURRENT_TOOLS=5
